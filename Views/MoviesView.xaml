<UserControl x:Class="MovieManagerDesktop.Views.MoviesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:MovieManagerDesktop.ViewModels"
             xmlns:converters="clr-namespace:MovieManagerDesktop.Converters"
             xmlns:controls="clr-namespace:MovieManagerDesktop.Controls"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:MoviesViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000"
             FlowDirection="RightToLeft"
             Loaded="MoviesView_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:SeriesStatusConverter x:Key="SeriesStatusConverter"/>
        <converters:SeriesStatusColorConverter x:Key="SeriesStatusColorConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="A" Modifiers="Ctrl" Command="{Binding SelectAllCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="Esc" Command="{Binding ExitSelectionModeCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshSelectedCommand}" />
    </UserControl.InputBindings>

    <Grid Margin="30,45,30,0" PreviewMouseWheel="Grid_PreviewMouseWheel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header, Search, Action Bar, and Filters -->
        <Grid Grid.Row="0" Margin="0,0,0,15" Height="45">
            <!-- Normal Mode -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="IsHitTestVisible" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInSelectionMode}" Value="True">
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding PageTitle}" Style="{StaticResource TextH2}" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <!-- Search -->
                <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="20" Padding="15,0" MaxWidth="350" HorizontalAlignment="Left" BorderBrush="{DynamicResource NormalBorder}" BorderThickness="1" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox IsEditable="True"
                                  Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                  ItemsSource="{Binding SearchHistory}"
                                  materialDesign:HintAssist.Hint="جستجو در کالکشن..." 
                                  Foreground="{DynamicResource PrimaryText}" FontSize="14" BorderThickness="0"
                                  VerticalAlignment="Center">
                            <ComboBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SaveSearchHistoryCommand}"/>
                                <KeyBinding Key="Enter" Command="{Binding SaveSearchHistoryCommand}"/>
                            </ComboBox.InputBindings>
                        </ComboBox>
                        <materialDesign:PackIcon Grid.Column="1" Kind="Magnify" Width="20" Height="20" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Action buttons: Sort, Filter, Size reset -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="FilterButton" Visibility="{Binding ShowFilters, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource PrimaryColor}" ToolTip="فیلترها" Padding="10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilterVariant" VerticalAlignment="Center"/>
                            <TextBlock Text="فیلترها" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Popup IsOpen="{Binding IsChecked, ElementName=FilterButton}" StaysOpen="False" PlacementTarget="{Binding ElementName=FilterButton}" Placement="Bottom">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="15" BorderBrush="{DynamicResource NormalBorder}" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="ترتیب نمایش:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                                <ComboBox SelectedIndex="{Binding SortIndex}" Width="150" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10">
                                    <ComboBoxItem Content="تاریخ افزودن"/>
                                    <ComboBoxItem Content="نام"/>
                                    <ComboBoxItem Content="سال تولید"/>
                                    <ComboBoxItem Content="امتیاز"/>
                                </ComboBox>

                                <TextBlock Text="جهت مرتب‌سازی:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                                <ComboBox SelectedIndex="{Binding SortDirectionIndex}" Width="150" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10">
                                    <ComboBoxItem Content="نزولی"/>
                                    <ComboBoxItem Content="صعودی"/>
                                </ComboBox>
                                
                                <TextBlock Text="ژانر:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Genres}" SelectedIndex="{Binding SelectedGenreIndex}" Width="150" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10" />

                                <TextBlock Text="نوع:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                                <ComboBox SelectedIndex="{Binding MediaTypeFilterIndex}" Width="150" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10">
                                    <ComboBoxItem Content="همه" />
                                    <ComboBoxItem Content="فیلم‌ها" />
                                    <ComboBoxItem Content="سریال‌ها" />
                                </ComboBox>

                                <TextBlock Text="وضعیت:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                                <ComboBox SelectedIndex="{Binding WatchedFilterIndex}" Width="150" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,10">
                                    <ComboBoxItem Content="همه" />
                                    <ComboBoxItem Content="دیده شده" />
                                    <ComboBoxItem Content="دیده نشده" />
                                </ComboBox>

                                <TextBlock Text="لیست:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                                <ComboBox SelectedIndex="{Binding ListFilterIndex}" Width="150" Foreground="{DynamicResource PrimaryText}">
                                    <ComboBoxItem Content="همه" />
                                    <ComboBoxItem Content="علاقه‌مندی‌ها" />
                                    <ComboBoxItem Content="لیست تماشا" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <ToggleButton x:Name="SizeButton" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource SecondaryText}" ToolTip="تغییر سایز پوستر" Padding="10,0" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImageSizeSelectActual" VerticalAlignment="Center"/>
                            <TextBlock Text="سایز" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>
                    
                    <Popup IsOpen="{Binding IsChecked, ElementName=SizeButton}" StaysOpen="False" PlacementTarget="{Binding ElementName=SizeButton}" Placement="Bottom">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="15" BorderBrush="{DynamicResource NormalBorder}" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="تغییر ابعاد:" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ImageSizeSelectSmall" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Slider Minimum="150" Maximum="350" Value="{Binding PosterSize}" Width="150" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}"/>
                                    <materialDesign:PackIcon Kind="ImageSizeSelectLarge" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <Button Command="{Binding ResetSizeCommand}" Content="بازگشت به سایز پیش‌فرض" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource SecondaryText}" Margin="0,15,0,0" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>

            <!-- Selection Action Bar Layer -->
            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="15,0" BorderBrush="{DynamicResource PrimaryColor}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5" Color="Black"/>
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInSelectionMode}" Value="True">
                                <Setter Property="IsHitTestVisible" Value="True"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding ExitSelectionModeCommand}" Style="{StaticResource MaterialDesignIconForegroundButton}" Foreground="{DynamicResource SecondaryText}" Width="30" Height="30" ToolTip="خروج (Esc)">
                        <materialDesign:PackIcon Kind="Close"/>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding SelectedCount, StringFormat='{}{0} مورد انتخاب شد'}" Foreground="{DynamicResource PrimaryText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding SelectAllCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource PrimaryColor}" Content="انتخاب همه" ToolTip="انتخاب همه (Ctrl+A)" Margin="0,0,10,0"/>
                        
                        <Button Command="{Binding ToggleFavoritesSelectedCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#FF4081" ToolTip="تغییر وضعیت علاقه‌مندی‌ها" Margin="0,0,5,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="HeartOutline" VerticalAlignment="Center"/>
                                <TextBlock Text="علاقه‌مندی" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ToggleWatchedSelectedCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource SuccessColor}" ToolTip="تغییر وضعیت مشاهده" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="EyeCheckOutline" VerticalAlignment="Center"/>
                                <TextBlock Text="وضعیت مشاهده" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding RefreshSelectedCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource WarningColor}" ToolTip="رفرش (F5)" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center"/>
                                <TextBlock Text="به‌روزرسانی" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteSelectedCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource ErrorColor}" ToolTip="حذف (Delete)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center"/>
                                <TextBlock Text="حذف" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Quick Filters -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10" Orientation="Horizontal" Visibility="{Binding ShowFilters, Converter={StaticResource BooleanToVisibilityConverter}}">
            <WrapPanel.Resources>
                <Style TargetType="ToggleButton">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#33000000"/>
                    <Setter Property="BorderBrush" Value="#55FFFFFF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="Padding" Value="12,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        CornerRadius="16" 
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Background" Value="#FF673AB7"/>
                                        <Setter Property="BorderBrush" Value="#FF673AB7"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#66000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </WrapPanel.Resources>

            <ToggleButton IsChecked="{Binding IsQuickFilterMovies}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="MovieOpen" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="فیلم‌ها" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            
            <ToggleButton IsChecked="{Binding IsQuickFilterSeries}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="TelevisionClassic" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="سریال‌ها" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>

            <ToggleButton IsChecked="{Binding IsQuickFilterUnwatched}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="EyeOutline" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="مشاهده نشده" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
        </WrapPanel>

        <!-- Progress bar for batch refresh -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="4" VerticalAlignment="Bottom" Background="Transparent" Foreground="#00E5FF" Visibility="{Binding IsRefreshing, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <!-- Movies Grid -->
        <Grid Grid.Row="2">
            <!-- Skeleton Loading Placeholders -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{DynamicResource {x:Type ScrollViewer}}" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <WrapPanel Margin="0,0,-20,0">
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                    <controls:ShimmerEffect Width="{Binding PosterSize}" Height="{Binding PosterHeight}" Margin="10,10,20,30" CornerRadius="12"/>
                </WrapPanel>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoMovies}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                
                <materialDesign:PackIcon Kind="FilmstripBoxMultiple" Width="120" Height="120" Foreground="{StaticResource TextDisabled}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="هنوز فیلمی اضافه نکرده‌اید!" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="برای شروع، پوشه فیلم‌های خود را اسکن کنید" FontSize="14" Foreground="{StaticResource TextDisabled}" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <Button Content="شروع اسکن" Command="{Binding GoToScanCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource PrimaryColor}" Foreground="#050510" 
                        Width="200" Height="45" FontSize="16" materialDesign:ButtonAssist.CornerRadius="8"
                        HorizontalAlignment="Center">
                    <Button.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                    </Button.Effect>
                </Button>
            </StackPanel>

            <!-- Actual Content -->
            <ListBox x:Name="MoviesItemsControl" ItemsSource="{Binding Movies}" SelectionMode="Extended" SelectionChanged="MoviesItemsControl_SelectionChanged" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Standard" ScrollViewer.CanContentScroll="True" Background="Transparent" BorderThickness="0" PreviewKeyDown="MoviesItemsControl_PreviewKeyDown" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="FocusBorder" BorderThickness="3" BorderBrush="Transparent" CornerRadius="12" Margin="2" Padding="0">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter TargetName="FocusBorder" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                            <Setter TargetName="FocusBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.5"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Panel.ZIndex" Value="100"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,20,0">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>
                
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <vwp:VirtualizingWrapPanel Orientation="Horizontal" SpacingMode="StartAndEndOnly" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="{Binding DataContext.PosterSize, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="10" CacheMode="BitmapCache">
                            
                            <!-- Main Card -->
                            <materialDesign:Card x:Name="posterCard" Background="{DynamicResource CardBackground}" UniformCornerRadius="12" RenderTransformOrigin="0.5,0.5" ClipToBounds="True">
                                <materialDesign:Card.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.5" Color="Black"/>
                                </materialDesign:Card.Effect>
                                <materialDesign:Card.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </materialDesign:Card.RenderTransform>
                                <materialDesign:Card.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.08" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.08" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="InfoOverlayTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="BadgeTransform" Storyboard.TargetProperty="Y" To="-65" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="InfoOverlayTransform" Storyboard.TargetProperty="Y" To="100" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="BadgeTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </materialDesign:Card.Triggers>
                                <materialDesign:Card.Style>
                                    <Style TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:Card.Style>
                                <Grid>
                                    <Border BorderBrush="{DynamicResource PrimaryColor}" BorderThickness="4" CornerRadius="12" Panel.ZIndex="1" IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                    </Border>
                                    <!-- Poster Click to Open Details -->
                                    <Button Command="{Binding DataContext.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Height" Value="Auto"/>
                                                <Setter Property="IsHitTestVisible" Value="True"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsInSelectionMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Grid>
                                            <!-- Full Poster -->
                                            <Image Source="{Binding File.PosterUrl, Converter={StaticResource ImageUrlToCachedImageConverter}}" Stretch="UniformToFill" Height="{Binding DataContext.PosterHeight, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                                            <!-- Watch Progress Bar -->
                                            <ProgressBar Value="{Binding File.WatchProgressPercent}" 
                                                         Maximum="100" 
                                                         Height="4" 
                                                         Background="#4C000000" 
                                                         Foreground="#E50914" 
                                                         BorderThickness="0" 
                                                         VerticalAlignment="Bottom" 
                                                         Panel.ZIndex="4">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding File.WatchProgressPercent}" Value="0">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>

                                            <!-- Play Button Overlay -->
                                            <Button Command="{Binding DataContext.PlayVideoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                                    Background="#CC000000"
                                                    BorderBrush="Transparent"
                                                    Foreground="White"
                                                    Width="36" Height="36"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Panel.ZIndex="5"
                                                    ToolTip="پخش با MPV">
                                                <Button.Visibility>
                                                    <Binding Path="IsMouseOver" RelativeSource="{RelativeSource AncestorType=materialDesign:Card}" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                                                </Button.Visibility>
                                                <materialDesign:PackIcon Kind="Play" Width="24" Height="24"/>
                                            </Button>                                            <!-- Sliding Info Overlay -->
                                            <Border x:Name="InfoOverlay" VerticalAlignment="Bottom" Background="#CC000000" Padding="12,10" Panel.ZIndex="2">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="InfoOverlayTransform" Y="100"/>
                                                </Border.RenderTransform>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding File.FormattedTitle}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <materialDesign:PackIcon Kind="Star" Foreground="{DynamicResource WarningColor}" VerticalAlignment="Center" Width="12" Height="12"/>
                                                        <TextBlock Text="{Binding File.Rating}" Foreground="#E0E0E0" FontSize="12" Margin="4,0,8,0"/>
                                                        <TextBlock Text="{Binding File.Year}" Foreground="#E0E0E0" FontSize="12" Margin="0,0,8,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Series Status Badge -->
                                            <Border CornerRadius="4" Padding="6,2" Background="{Binding File.SeriesStatus, Converter={StaticResource SeriesStatusColorConverter}}" Visibility="{Binding File.SeriesStatus, Converter={StaticResource NullToVisibilityConverter}}" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10" Panel.ZIndex="3" IsHitTestVisible="False">
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="BadgeTransform" Y="0"/>
                                                </Border.RenderTransform>
                                                <TextBlock Text="{Binding File.SeriesStatus, Converter={StaticResource SeriesStatusConverter}}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Button>

                                    <!-- Top Overlay (Checkbox and Icons) -->
                                    <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Padding="8" Background="Transparent" CornerRadius="12,12,0,0" Panel.ZIndex="5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Border to ensure CheckBox is visible -->
                                            <Border Grid.Column="0" Background="#99000000" CornerRadius="4" Padding="4" HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="10" Margin="4">
                                                <CheckBox IsChecked="{Binding IsSelected}" Foreground="{DynamicResource PrimaryColor}" BorderBrush="White">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsSelectionMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=posterCard}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </Border>
                                            
                                            
                                            <!-- Series Status Badge (Removed from here, moved to hover overlay) -->
                                            
                                            <Border Grid.Column="2" Background="#99000000" CornerRadius="8" Padding="2" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <!-- Favorite Toggle -->
                                                <Button Command="{Binding ToggleFavoriteCommand}"
                                                        Style="{StaticResource MaterialDesignIconForegroundButton}" Width="28" Height="28" Padding="0">
                                                    <materialDesign:PackIcon Kind="Heart" Foreground="{Binding FavoriteIconForeground}" Width="18" Height="18"/>
                                                </Button>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Updating Overlay -->
                                    <Border Background="#B3000000" CornerRadius="12" Visibility="{Binding IsUpdating, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <ProgressBar IsIndeterminate="True" Style="{StaticResource MaterialDesignCircularProgressBar}" Foreground="{DynamicResource PrimaryColor}"/>
                                            <TextBlock Text="در حال بروزرسانی..." Foreground="{DynamicResource PrimaryText}" Margin="0,10,0,0" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <!-- Bulk Action Progress Overlay -->
            <Border Background="#CC000000" VerticalAlignment="Bottom" Padding="20" Visibility="{Binding IsBulkActionRunning, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="50">
                <Grid MaxWidth="400" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="{Binding BulkActionText}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ProgressBar Value="{Binding BulkActionProgress}" Height="8" Minimum="0" Maximum="100" 
                                     Foreground="{DynamicResource PrimaryColor}" Background="{DynamicResource MainBackground}" BorderThickness="0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding CancelBulkActionCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#FF5252" BorderBrush="#FF5252" Content="لغو" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>

