<UserControl x:Class="MovieManagerDesktop.Views.SeriesDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:MovieManagerDesktop.Converters"
             Background="{DynamicResource Background}"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <converters:ImageUrlToCachedImageConverter x:Key="ImageUrlToCachedImageConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:SeriesStatusConverter x:Key="SeriesStatusConverter" />
        <converters:SeasonNameConverter x:Key="SeasonNameConverter" />
    </UserControl.Resources>

    <Grid Margin="0,40,0,0">
        <!-- Loading Overlay -->
        <ProgressBar IsIndeterminate="True" 
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Width="40" Height="40" Style="{StaticResource MaterialDesignCircularProgressBar}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="10"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Hero Section -->
                <Grid Height="350">
                    <Image Source="{Binding Series.BackdropUrl, Converter={StaticResource ImageUrlToCachedImageConverter}}" 
                           Stretch="UniformToFill" />
                    
                    <!-- Gradient Overlay -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#22000000" Offset="0"/>
                                <GradientStop Color="#DD000000" Offset="0.7"/>
                                <GradientStop Color="#FF000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20">
                        <Button Command="{Binding GoBackCommand}" 
                                Background="#80000000" BorderThickness="0" 
                                Foreground="White" Width="50" Height="50"
                                materialDesign:ButtonAssist.CornerRadius="25">
                            <materialDesign:PackIcon Kind="ArrowRight" Width="30" Height="30"/>
                        </Button>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
                        <!-- Favorite Button -->
                        <Button Command="{Binding ToggleFavoriteCommand}" 
                                Background="#80000000" BorderThickness="0"
                                Foreground="White" Width="50" Height="50" Padding="0" Margin="0,0,10,0"
                                materialDesign:ButtonAssist.CornerRadius="25"
                                ToolTip="افزودن/حذف از علاقه‌مندی‌ها">
                            <materialDesign:PackIcon Kind="{Binding FavoriteIconKind}" Width="24" Height="24" Foreground="{Binding FavoriteIconColor}"/>
                        </Button>
                        
                        <!-- Operations Menu -->
                        <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                                  StaysOpen="False"
                                                  ToolTip="عملیات بیشتر">
                            <materialDesign:PopupBox.ToggleContent>
                                <Border Background="#80000000" Width="50" Height="50" CornerRadius="25">
                                    <materialDesign:PackIcon Kind="DotsVertical" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </materialDesign:PopupBox.ToggleContent>
                            <StackPanel MinWidth="220">
                                <Button Command="{Binding RefreshSeriesCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="بروز رسانی" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ChangePosterCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ImageEdit" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="دریافت مجدد پوستر" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding RefreshTrackerCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="RadarOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="دریافت اطلاعات ردیاب" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    </StackPanel>
                                </Button>
                                <Separator/>
                                <Button Command="{Binding DeleteSeriesCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10" Foreground="#FF5252">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="حذف سریال" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:PopupBox>
                    </StackPanel>

                    <Grid VerticalAlignment="Bottom" Margin="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="8" ClipToBounds="True" Width="140" Height="210" BorderThickness="2" BorderBrush="#55FFFFFF" Margin="0,0,20,0">
                            <Image Source="{Binding Series.PosterUrl, Converter={StaticResource ImageUrlToCachedImageConverter}}" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,10">
                            <TextBlock Text="{Binding Series.FormattedTitle}" FontSize="36" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <materialDesign:PackIcon Kind="Star" Foreground="#FFD700" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Series.Rating, StringFormat={}{0:F1}}" Foreground="White" FontSize="16" FontWeight="Bold" Margin="5,0,20,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel HorizontalAlignment="Center" Margin="30,80" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Width="80" Height="80" Foreground="{DynamicResource ErrorColor}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorColor}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,20,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <!-- Series Tracker Section -->
                <Border Background="{DynamicResource CardBackground}" 
                        CornerRadius="16" 
                        Padding="20" 
                        Margin="30,0,30,30"
                        BorderBrush="{DynamicResource NormalBorder}"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Header -->
                        <Grid Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <materialDesign:PackIcon Kind="TelevisionClassic" 
                                                         Width="24" Height="24" 
                                                         Foreground="{DynamicResource PrimaryColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <TextBlock Text="اطلاعات پخش سریال" 
                                           Foreground="{DynamicResource PrimaryText}" 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Status Badge -->
                            <Border Background="#1A4CAF50" 
                                    CornerRadius="16" 
                                    Padding="12,6" 
                                    HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{Binding SeriesStatusColor}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SeriesStatusText}" 
                                               Foreground="{Binding SeriesStatusColor}"
                                               FontSize="14" 
                                               FontWeight="SemiBold" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <Separator Background="{DynamicResource NormalBorder}" Margin="0,0,0,15"/>
                        
                        <!-- Info Grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- First Air Date -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <materialDesign:PackIcon Kind="CalendarStart" 
                                                         Width="20" Height="20" 
                                                         Foreground="{DynamicResource PrimaryColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="شروع پخش" 
                                               Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding FirstAirDateText}" 
                                               Foreground="{DynamicResource PrimaryText}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Last Air Date -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15">
                                <materialDesign:PackIcon Kind="CalendarEnd" 
                                                         Width="20" Height="20" 
                                                         Foreground="{DynamicResource PrimaryColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="آخرین پخش" 
                                               Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding LastAirDateText}" 
                                               Foreground="{DynamicResource PrimaryText}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Network -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,15">
                                <materialDesign:PackIcon Kind="Television" 
                                                         Width="20" Height="20" 
                                                         Foreground="{DynamicResource PrimaryColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="شبکه پخش" 
                                               Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding NetworkText}" 
                                               Foreground="{DynamicResource PrimaryText}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Air Schedule -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15">
                                <materialDesign:PackIcon Kind="ClockOutline" 
                                                         Width="20" Height="20" 
                                                         Foreground="{DynamicResource PrimaryColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="زمان پخش" 
                                               Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding AirScheduleText}" 
                                               Foreground="{DynamicResource PrimaryText}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Episodes Info -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Filmstrip" 
                                                         Width="20" Height="20" 
                                                         Foreground="{DynamicResource PrimaryColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="تعداد کل" 
                                               Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding EpisodesInfoText}" 
                                               Foreground="{DynamicResource PrimaryText}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- Next Episode -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowRightBold" 
                                                         Width="20" Height="20" 
                                                         Foreground="{DynamicResource ErrorColor}" 
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <StackPanel>
                                    <TextBlock Text="قسمت بعدی" 
                                               Foreground="{DynamicResource SecondaryText}" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding NextEpisodeText}" 
                                               Foreground="{DynamicResource ErrorColor}" 
                                               FontSize="14" 
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>


                <!-- Seasons and Episodes -->
                <ItemsControl ItemsSource="{Binding Seasons}" Margin="30,20,30,40">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,30">
                                <TextBlock Text="{Binding Season.Name, Converter={StaticResource SeasonNameConverter}}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,15"/>
                                
                                <ItemsControl ItemsSource="{Binding Episodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Margin="0,0,0,12" Padding="15" BorderThickness="1" BorderBrush="{DynamicResource NormalBorder}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource HoverBackground}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}" />
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsWatched}" 
                                                              Command="{Binding DataContext.ToggleEpisodeWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"
                                                              Style="{StaticResource MaterialDesignCheckBox}"
                                                              VerticalAlignment="Center" Margin="0,0,15,0">
                                                        <CheckBox.LayoutTransform>
                                                            <ScaleTransform ScaleX="1.5" ScaleY="1.5" />
                                                        </CheckBox.LayoutTransform>
                                                    </CheckBox>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}">
                                                            <Run Text="قسمت "/>
                                                            <Run Text="{Binding EpisodeNumber}"/>
                                                            <Run Text=" - "/>
                                                            <Run Text="{Binding Name}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding AirDate}" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,10"/>
                                                        <TextBlock Text="{Binding Overview}" FontSize="13" Foreground="{DynamicResource SecondaryText}" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
