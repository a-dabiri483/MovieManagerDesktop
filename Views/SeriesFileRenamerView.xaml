<UserControl x:Class="MovieManagerDesktop.Views.SeriesFileRenamerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:MovieManagerDesktop.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:SeriesFileRenamerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource MainBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Compact DataGrid Style (Copied from ScanView) -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NormalBorder}"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource NormalBorder}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource NormalBorder}"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NormalBorder}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryColor}"/>
                    <Setter Property="Foreground" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2000B4D8"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,60,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Controls -->
            <RowDefinition Height="Auto"/> <!-- Progress -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Title -->
            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="RenameBox" Width="28" Height="28" Foreground="{DynamicResource InfoColor}" Margin="0,0,10,0"/>
                    <TextBlock Text="تغییر نام هوشمند فایل‌های سریال" Style="{StaticResource TextH2}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Margin="38,5,0,0"
                           Text="یک پوشه را انتخاب کنید تا نام فایل‌های ویدئویی و زیرنویس آن بررسی و بر اساس سرور به استانداردی تمیز تغییر یابد."
                           Foreground="{DynamicResource SecondaryText}" FontSize="13" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Controls (Row 1) -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackground}" 
                BorderBrush="{DynamicResource NormalBorder}" BorderThickness="1" 
                CornerRadius="8" Padding="15" Margin="0,15,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: Mode Selection & Input -->
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="منبع نام‌گذاری:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource SecondaryText}"/>
                    <RadioButton Content="نام پوشه (پیش‌فرض)" IsChecked="{Binding IsAutoMode}" Margin="0,0,15,0" Foreground="{DynamicResource PrimaryText}"/>
                    <RadioButton Content="نام دستی (کاستوم)" IsChecked="{Binding IsCustomMode}" Margin="0,0,15,0" Foreground="{DynamicResource PrimaryText}"/>
                    <RadioButton Content="دریافت از سرور API" IsChecked="{Binding IsApiMode}" Margin="0,0,25,0" Foreground="{DynamicResource PrimaryText}"/>

                    <!-- Custom Name Input -->
                    <TextBox Text="{Binding CustomBaseName, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding IsAutoMode, Converter={StaticResource InverseBooleanConverter}}"
                             materialDesign:HintAssist.Hint="نام پایه برای اعمال روی همه فایل‌ها..."
                             Foreground="{DynamicResource PrimaryText}" 
                             FontSize="13" 
                             Width="250"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>

                    <!-- TMDB Search Button -->
                    <Button Command="{Binding SearchApiCommand}"
                            Visibility="{Binding IsApiMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="{DynamicResource PrimaryColor}" Foreground="#050510" 
                            Height="32" Padding="15,0" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CloudSearch" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="جستجو" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Row 1: Action Controls -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Text="{Binding SelectedFolderPath, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="مسیر پوشه سریال..."
                             Foreground="{DynamicResource PrimaryText}" 
                             FontSize="13" 
                             Width="350"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>
                    <Button Command="{Binding SelectFolderCommand}"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="{DynamicResource SecondaryText}"
                            ToolTip="انتخاب پوشه"
                            Width="30" Height="30" Padding="0" Margin="0,0,5,0">
                        <materialDesign:PackIcon Kind="FolderOpen"/>
                    </Button>
                </StackPanel>

                <Button Grid.Row="1" Grid.Column="1" Command="{Binding ScanFolderCommand}"
                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource SuccessColor}" Foreground="#050510" Margin="15,0,0,0" Width="120">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Search" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="اسکن" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="1" Grid.Column="2" Command="{Binding ApplyChangesCommand}" 
                        IsEnabled="{Binding IsApplying, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource InfoColor}" Foreground="#050510" Margin="15,0,0,0" Width="140">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckAll" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="اعمال تغییرات" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Progress (Row 2) -->
        <ProgressBar Grid.Row="2" IsIndeterminate="{Binding IsScanning}" 
                     Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Height="4" Margin="0,0,0,10" Foreground="{DynamicResource SuccessColor}"/>
        
        <ProgressBar Grid.Row="2" IsIndeterminate="{Binding IsApplying}" 
                     Visibility="{Binding IsApplying, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Height="4" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryColor}"/>

        <!-- DataGrid (Row 3) -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Items}" 
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  x:Name="MainDataGrid"
                  Tag="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}">
            <DataGrid.ContextMenu>
                <ContextMenu Background="{DynamicResource MainBackground}" Foreground="{DynamicResource PrimaryText}">
                    <MenuItem Header="تیک زدن موارد انتخاب شده" 
                              Command="{Binding PlacementTarget.Tag.DataContext.CheckSelectedItemsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Visibility="{Binding PlacementTarget.SelectedItems.Count, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource MultipleSelectionToVisibilityConverter}}">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="CheckboxMarked" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="برداشتن تیک موارد انتخاب شده" 
                              Command="{Binding PlacementTarget.Tag.DataContext.UncheckSelectedItemsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Visibility="{Binding PlacementTarget.SelectedItems.Count, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource MultipleSelectionToVisibilityConverter}}">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="CheckboxBlankOutline" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <!-- CheckBox Column -->
                <DataGridTemplateColumn Width="50">
                    <DataGridTemplateColumn.Header>
                        <CheckBox IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                      IsEnabled="{Binding IsRenamed, Converter={StaticResource InverseBooleanConverter}}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignCheckBox}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Icon Column -->
                <DataGridTemplateColumn Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:PackIcon Kind="FileVideo" 
                                                     Visibility="{Binding IsVideo, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Foreground="{DynamicResource InfoColor}" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:PackIcon Kind="Subtitles" 
                                                     Visibility="{Binding IsSubtitle, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Foreground="{DynamicResource WarningColor}" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Original Name -->
                <DataGridTextColumn Header="نام فعلی (Original)" Binding="{Binding OriginalFileName}" Width="2*" 
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- New Name -->
                <DataGridTextColumn Header="پیش‌نمایش نام جدید (New)" Binding="{Binding NewFileName}" Width="2*" 
                                    IsReadOnly="False">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Status -->
                <DataGridTextColumn Header="وضعیت" Binding="{Binding Status}" Width="*" 
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="آماده">
                                    <Setter Property="Foreground" Value="{DynamicResource InfoColor}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="انجام شد">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="خطا">
                                    <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
