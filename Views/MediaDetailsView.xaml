<UserControl x:Class="MovieManagerDesktop.Views.MediaDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             FlowDirection="RightToLeft"
             Focusable="True">

    <UserControl.InputBindings>
        <KeyBinding Key="Esc" Command="{Binding GoBackCommand}" />
        <KeyBinding Key="Space" Command="{Binding PlayMovieCommand}" />
        <KeyBinding Key="Enter" Command="{Binding PlayMovieCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.Resources>
            <materialDesign:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
            <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="SecondaryText" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="CardBackground" Color="#20FFFFFF"/>
            <SolidColorBrush x:Key="HoverBackground" Color="#40FFFFFF"/>
            <SolidColorBrush x:Key="NormalBorder" Color="#40FFFFFF"/>
            <SolidColorBrush x:Key="LightBorder" Color="#20FFFFFF"/>
        </Grid.Resources>
        <!-- Backdrop Image with Gradient Overlay and Vignette -->
        <Grid>
            <Image x:Name="BackdropImage" Source="{Binding Media.BackdropUrl, Converter={StaticResource ImageUrlToCachedImageConverter}}" Stretch="UniformToFill" Opacity="0.75">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="BackdropTranslate" Y="0"/>
                </Image.RenderTransform>
            </Image>
            
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#990A0A1A" Offset="0"/>
                        <GradientStop Color="#D90A0A1A" Offset="0.6"/>
                        <GradientStop Color="#FF0A0A1A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <!-- Vignette -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="Transparent" Offset="0.3"/>
                        <GradientStop Color="#80000000" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Grid>
        
        <Grid Margin="40,60,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header (Back Button & Title) -->
            <Grid Margin="0,0,0,30" Panel.ZIndex="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding GoBackCommand}" 
                        Background="#80000000" BorderThickness="0" 
                        Foreground="{DynamicResource PrimaryText}" Width="50" Height="50" Margin="0,0,20,0" 
                        ToolTip="بازگشت" materialDesign:ButtonAssist.CornerRadius="25">
                    <materialDesign:PackIcon Kind="ArrowRight" Width="30" Height="30"/>
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding Media.FormattedTitle}" Foreground="{DynamicResource PrimaryText}" FontSize="30" FontWeight="Black" VerticalAlignment="Center" TextWrapping="Wrap">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.8" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Favorite Button -->
                    <Button Command="{Binding ToggleFavoriteCommand}" 
                            Background="{DynamicResource CardBackground}" BorderThickness="1" BorderBrush="{DynamicResource NormalBorder}"
                            Foreground="{DynamicResource PrimaryText}" Width="50" Height="50" Padding="0"
                            materialDesign:ButtonAssist.CornerRadius="25"
                            ToolTip="افزودن/حذف از علاقه‌مندی‌ها" Margin="0,0,10,0">
                        <materialDesign:PackIcon Kind="{Binding FavoriteIconKind}" Width="24" Height="24" Foreground="{Binding FavoriteIconColor}"/>
                    </Button>
                    <Button Command="{Binding ToggleWatchedCommand}" 
                            Background="{DynamicResource CardBackground}" BorderThickness="1" BorderBrush="{DynamicResource NormalBorder}"
                        Foreground="{DynamicResource PrimaryText}" Height="50" Padding="15,0"
                        materialDesign:ButtonAssist.CornerRadius="25"
                        ToolTip="تغییر وضعیت دیده شده/نشده">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="EyeOffOutline"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                            <Setter Property="Kind" Value="EyeCheck"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                        <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="دیده نشده"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                            <Setter Property="Text" Value="دیده شده"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>
                
                    <!-- Operations Menu -->
                    <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                             StaysOpen="False"
                                             Margin="10,0,0,0"
                                             Foreground="{DynamicResource PrimaryText}"
                                             ToolTip="عملیات بیشتر"
                                             VerticalAlignment="Center">
                        <materialDesign:PopupBox.ToggleContent>
                            <Border Background="{DynamicResource CardBackground}" BorderThickness="1" BorderBrush="{DynamicResource NormalBorder}" Width="50" Height="50" CornerRadius="25">
                                <materialDesign:PackIcon Kind="DotsVertical" Width="24" Height="24" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </materialDesign:PopupBox.ToggleContent>
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="8">
                            <StackPanel MinWidth="220" Margin="0,8">
                                <Button Command="{Binding UpdateSeriesTrackerCommand}" 
                                        Visibility="{Binding IsSeries, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10" Height="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="Sync" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="1" Text="بروزرسانی اطلاعات ردیاب" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </Grid>
                                </Button>
                                
                                <Button Command="{Binding RefreshDataCommand}" 
                                        Visibility="{Binding IsMovie, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10" Height="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="Refresh" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="1" Text="بروز رسانی" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ManualIdentifyCommand}" 
                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10" Height="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="DatabaseSearch" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="1" Text="شناسایی دستی (ویرایش)" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ChangePosterCommand}" 
                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalContentAlignment="Right" Padding="15,10" Height="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="ImageEdit" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="1" Text="دریافت مجدد پوستر" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </Grid>
                                </Button>
                                
                                <Separator Background="{DynamicResource NormalBorder}" Margin="0,4"/>
                                
                                <Button Command="{Binding DeleteMovieCommand}" 
                                        Style="{StaticResource MaterialDesignFlatButton}" 
                                        Foreground="#FF5252" 
                                        HorizontalContentAlignment="Right" Padding="15,10" Height="Auto">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="DeleteOutline" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="1" Text="حذف" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </materialDesign:PopupBox>
                </StackPanel>
            </Grid>
            
            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Poster -->
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Width="320" Margin="0,0,40,0" Panel.ZIndex="5">
                    <StackPanel.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.5" Color="Black"/>
                    </StackPanel.Effect>
                    
                    <Border CornerRadius="{StaticResource RadiusLg}" Height="480" Background="#20FFFFFF" BorderBrush="{DynamicResource NormalBorder}" BorderThickness="1">
                        <Border CornerRadius="{StaticResource RadiusLg}" ClipToBounds="True">
                            <Image Source="{Binding Media.PosterUrl, Converter={StaticResource ImageUrlToCachedImageConverter}}" Stretch="UniformToFill" />
                        </Border>
                    </Border>
                    
                    <!-- Reflection Simulation -->
                    <Border CornerRadius="{StaticResource RadiusLg}" Height="480" ClipToBounds="True" Opacity="0.4" Margin="0,5,0,-480">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="-1" CenterY="240"/>
                        </Border.RenderTransform>
                        <Border.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.6"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.OpacityMask>
                        <Image Source="{Binding Media.PosterUrl, Converter={StaticResource ImageUrlToCachedImageConverter}}" Stretch="UniformToFill" />
                    </Border>
                    
                    <!-- Play Movie Button -->
                    <Button Command="{Binding PlayMovieCommand}" Visibility="{Binding IsMovie, Converter={StaticResource BooleanToVisibilityConverter}}" 
                            Margin="0,20,0,0" Height="55" FontSize="18" FontWeight="Bold"
                            Background="{DynamicResource PrimaryColor}" BorderBrush="{DynamicResource PrimaryColor}" Foreground="White" materialDesign:ButtonAssist.CornerRadius="12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="پخش فیلم" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Details -->
                <ScrollViewer x:Name="DetailsScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,20,0" ScrollChanged="DetailsScrollViewer_ScrollChanged">
                    <StackPanel>
                        <!-- Metadata Badges -->
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,30">
                            <!-- Year -->
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="15,6" Margin="0,0,15,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Calendar" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Media.Year}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Rating -->
                            <Border Background="#33FFC107" BorderBrush="#FFFFC107" BorderThickness="1" CornerRadius="16" Padding="15,6" Margin="0,0,15,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Star" Foreground="#FFFFC107" VerticalAlignment="Center" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Media.Rating}" Foreground="#FFFFC107" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Quality -->
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="15,6" Margin="0,0,15,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="HighDefinition" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Media.Quality}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Type -->
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="15,6" Margin="0,0,15,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Movie" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Width="18" Height="18" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Media.MediaType}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <!-- Genres -->
                            <TextBlock Text="{Binding Media.Genres}" Foreground="{DynamicResource PrimaryColor}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,25" TextWrapping="Wrap"/>
                            
                            <!-- Overview -->
                            <TextBlock Text="خلاصه داستان" Foreground="{DynamicResource PrimaryText}" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="{Binding Media.Overview}" Foreground="{DynamicResource SecondaryText}" FontSize="16" LineHeight="30" TextWrapping="Wrap" Margin="0,0,0,35" TextAlignment="Justify"/>

                            <!-- Director -->
                            <TextBlock Text="کارگردان" Foreground="{DynamicResource PrimaryText}" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="{Binding Media.Director}" Foreground="{DynamicResource SecondaryText}" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,30"/>

                            <!-- Actors -->
                            <TextBlock Text="بازیگران" Foreground="{DynamicResource PrimaryText}" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="{Binding Media.Actors}" Foreground="{DynamicResource SecondaryText}" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,35" LineHeight="26"/>
                            
                            <!-- Series/Anime Tracker Section -->
                            <StackPanel Visibility="{Binding ShowSeriesTracker, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,30">
                                <TextBlock Text="اطلاعات ردیابی سریال/انیمه" Foreground="{DynamicResource PrimaryText}" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                                
                                <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" BorderBrush="{DynamicResource HoverBackground}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- وضعیت پخش (Badge) -->
                                        <Border Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" CornerRadius="16" Padding="12,6" Margin="0,0,0,15" Background="{DynamicResource HoverBackground}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Fill="{Binding SeriesStatusColor}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding SeriesStatusText}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{Binding SeriesStatusColor}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- تاریخ شروع -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,15">
                                            <materialDesign:PackIcon Kind="CalendarStart" Width="18" Height="18" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="شروع پخش" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding FirstAirDateText}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- تاریخ پایان -->
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15">
                                            <materialDesign:PackIcon Kind="CalendarEnd" Width="18" Height="18" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="پایان پخش" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding LastAirDateText}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- شبکه/استودیو -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,15">
                                            <materialDesign:PackIcon Kind="Television" Width="18" Height="18" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="استودیو / شبکه" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding NetworkText}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- برنامه پخش -->
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15">
                                            <materialDesign:PackIcon Kind="ClockOutline" Width="18" Height="18" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="برنامه پخش" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding AirScheduleText}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- تعداد قسمتها -->
                                        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,15">
                                            <materialDesign:PackIcon Kind="Filmstrip" Width="18" Height="18" Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="تعداد قسمتها" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding EpisodesInfoText}" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- قسمت بعدی -->
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15">
                                            <materialDesign:PackIcon Kind="ArrowRightBold" Width="18" Height="18" Foreground="#FFFF9800" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="قسمت بعدی" Foreground="{DynamicResource SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding NextEpisodeText}" Foreground="#FFFF9800" FontSize="14" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Episodes Section (Series Only) -->
                            <StackPanel Visibility="{Binding HasEpisodes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="فایل‌ها و قسمت‌ها" Foreground="{DynamicResource PrimaryText}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Command="{Binding PlayLastEpisodeCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource PrimaryColor}" FontSize="15" FontWeight="Bold">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Play" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="پخش ادامه" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                
                                <ItemsControl ItemsSource="{Binding Seasons}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,30">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                    <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                                    <CheckBox IsChecked="{Binding IsWatched}" 
                                                              Command="{Binding DataContext.ToggleSeasonWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                              CommandParameter="{Binding}"
                                                              Margin="15,0,0,0" VerticalAlignment="Center" 
                                                              Content="دیده شده" Foreground="{DynamicResource SecondaryText}"/>
                                                </StackPanel>
                                                
                                                <ItemsControl ItemsSource="{Binding Episodes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="12" Margin="0,0,0,15" Padding="15">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                                                        <Setter Property="BorderThickness" Value="4,0,0,0"/>
                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                                                            </Trigger>
                                                                            <DataTrigger Binding="{Binding IsWatched}" Value="True">
                                                                                <Setter Property="Opacity" Value="0.6"/>
                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid x:Name="EpGrid">
                                                                    <Grid.RenderTransform>
                                                                        <TranslateTransform X="0"/>
                                                                    </Grid.RenderTransform>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsWatched}" Command="{Binding DataContext.ToggleEpisodeWatchedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignCheckBox}" VerticalAlignment="Center" Margin="0,0,15,0">
                                                                        <CheckBox.LayoutTransform>
                                                                            <ScaleTransform ScaleX="1.3" ScaleY="1.3" />
                                                                        </CheckBox.LayoutTransform>
                                                                    </CheckBox>
                                                                    
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding FormattedTitle}" Foreground="{DynamicResource PrimaryText}" FontSize="18" FontWeight="SemiBold"/>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                            <TextBlock Text="فصل" Foreground="{DynamicResource SecondaryText}" FontSize="14" Margin="0,0,5,0"/>
                                                                            <TextBlock Text="{Binding Season}" Foreground="{DynamicResource PrimaryColor}" FontSize="14" Margin="0,0,15,0"/>
                                                                            <TextBlock Text="قسمت" Foreground="{DynamicResource SecondaryText}" FontSize="14" Margin="0,0,5,0"/>
                                                                            <TextBlock Text="{Binding Episode}" Foreground="{DynamicResource PrimaryColor}" FontSize="14"/>
                                                                            <TextBlock Text="{Binding Quality}" Foreground="{DynamicResource WarningColor}" FontSize="14" Margin="15,0,0,0" FontWeight="Bold"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    
                                                                    <Button Grid.Column="2" Content="پخش فایل" Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{DynamicResource PrimaryColor}" BorderBrush="{DynamicResource PrimaryColor}" BorderThickness="1" materialDesign:ButtonAssist.CornerRadius="8" Padding="15,0"/>
                                                                </Grid>
                                                                <Border.Triggers>
                                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="EpGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="-8" Duration="0:0:0.2"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="EpGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </EventTrigger>
                                                                </Border.Triggers>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

