<Window x:Class="MovieManagerDesktop.Views.PlayerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تنظیمات پلیر" SizeToContent="Height" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#E6121212" CornerRadius="15" BorderBrush="#33FFFFFF" BorderThickness="1">
        <!-- Blur Effect (Optional) -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="تنظیمات پخش" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource MaterialDesignIconForegroundButton}" 
                        Width="30" Height="30" Padding="0" Click="CloseButton_Click">
                    <materialDesign:PackIcon Kind="Close" Foreground="#FF5252" Width="20" Height="20"/>
                </Button>
            </Grid>
            
            <Separator Grid.Row="1" Background="#33FFFFFF" Margin="0,0,0,15"/>

            <!-- Controls -->
            <StackPanel Grid.Row="2">
                
                <!-- Speed -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="Speedometer" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="-" Width="40" Height="30" Padding="0" Margin="0,0,5,0" Click="SpeedDown_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#55FFFFFF"/>
                        <TextBlock x:Name="SpeedText" Text="1.0x" Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,5,0" Width="40" TextAlignment="Center"/>
                        <Button Content="+" Width="40" Height="30" Padding="0" Click="SpeedUp_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#55FFFFFF"/>
                    </StackPanel>
                </Grid>

                <!-- Subtitle Delay -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="ClockOutline" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="هماهنگی زیرنویس"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="-0.1s" Width="55" Height="30" Padding="0" Margin="0,0,5,0" Click="SubDelayDown_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#55FFFFFF" FontSize="11"/>
                        <TextBlock x:Name="SubDelayText" Text="0.0s" Foreground="#2196F3" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,5,0" Width="40" TextAlignment="Center"/>
                        <Button Content="+0.1s" Width="55" Height="30" Padding="0" Click="SubDelayUp_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#55FFFFFF" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Audio Delay -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="SpeakerGroup" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="هماهنگی صدا"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="-0.1s" Width="55" Height="30" Padding="0" Margin="0,0,5,0" Click="AudioDelayDown_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#55FFFFFF" FontSize="11"/>
                        <TextBlock x:Name="AudioDelayText" Text="0.0s" Foreground="#FF9800" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,5,0" Width="40" TextAlignment="Center"/>
                        <Button Content="+0.1s" Width="55" Height="30" Padding="0" Click="AudioDelayUp_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="White" BorderBrush="#55FFFFFF" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Subtitle -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="SubtitlesOutline" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="تغییر زیرنویس" HorizontalAlignment="Right" Click="CycleSubtitle_Click" Style="{StaticResource MaterialDesignFlatMidBgButton}" Background="#33FFFFFF" Foreground="White" Padding="15,0"/>
                </Grid>

                <!-- Audio -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="VolumeHigh" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="تغییر صدای دوبله" HorizontalAlignment="Right" Click="CycleAudio_Click" Style="{StaticResource MaterialDesignFlatMidBgButton}" Background="#33FFFFFF" Foreground="White" Padding="15,0"/>
                </Grid>

                <!-- Skip Intro -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Kind="FastForwardOutline" Foreground="White" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="رد کردن تیتراژ (۸۵ ثانیه)" HorizontalAlignment="Right" Click="SkipIntro_Click" Style="{StaticResource MaterialDesignFlatMidBgButton}" Background="#33FFFFFF" Foreground="White" Padding="15,0"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
