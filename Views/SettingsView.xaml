<UserControl x:Class="MovieManagerDesktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:MovieManagerDesktop.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="40,50,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Command="{Binding GoBackCommand}" 
                Background="Transparent" BorderThickness="0" 
                Foreground="{DynamicResource SecondaryText}" 
                HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ArrowRight" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="بازگشت" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

        <TextBlock Grid.Row="1" Text="تنظیمات نرم افزار" Style="{StaticResource TextH2}" Margin="0,0,0,30">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5" Color="Black"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Main Tab Layout -->
        <TabControl Grid.Row="2" TabStripPlacement="Right" Background="Transparent" BorderThickness="0">
            <!-- Sidebar / Tab Styling -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="15,16"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12" Margin="0,0,30,0">
                                    <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HoverBackground}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A3A86FF"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- 1. General Settings -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" MinWidth="180">
                        <materialDesign:PackIcon Kind="CogOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="عمومی" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,20,0">
                    <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                        <!-- Data Source Card -->
                        <materialDesign:Card Background="{DynamicResource CardBackground}" UniformCornerRadius="16" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="منبع دریافت اطلاعات فیلم‌ها" Foreground="{DynamicResource PrimaryText}" FontSize="20" FontWeight="Bold" Margin="0,0,0,25"/>
                                
                                <!-- FM-DB -->
                                <RadioButton IsChecked="{Binding IsFmDbSelected}" Content="سایت FM-DB (پیشنهادی - کاملا رایگان و بدون نیاز به کلید)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,0,15" GroupName="DataSources"/>
                                
                                <!-- TMDB -->
                                <RadioButton IsChecked="{Binding IsTmdbSelected}" Content="سایت TMDb (نیازمند دریافت کلید از سایت)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,0,10" GroupName="DataSources"/>
                                <TextBox Text="{Binding TmdbApiKey, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:HintAssist.Hint="کلید API سایت TMDb" 
                                         Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="35,0,0,20"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         IsEnabled="{Binding IsTmdbSelected}"/>

                                <!-- OMDB -->
                                <RadioButton IsChecked="{Binding IsOmdbSelected}" Content="سایت OMDb (نیازمند دریافت کلید از سایت)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,0,10" GroupName="DataSources"/>
                                <TextBox Text="{Binding OmdbApiKey, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:HintAssist.Hint="کلید API سایت OMDb" 
                                         Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="35,0,0,30"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         IsEnabled="{Binding IsOmdbSelected}"/>

                                 <Separator Background="{DynamicResource NormalBorder}" Margin="0,10,0,25"/>

                                <!-- Player Settings -->
                                <TextBlock Text="تنظیمات پخش‌کننده (Player)" Foreground="{DynamicResource PrimaryText}" FontSize="20" FontWeight="Bold" Margin="0,0,0,25"/>
                                
                                <RadioButton IsChecked="{Binding IsCustomPlayer}" Content="پخش‌کننده پیش‌فرض ویندوز (Custom)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,0,15" GroupName="PlayerSelection"/>
                                
                                <RadioButton IsChecked="{Binding IsPluginPlayer}" Content="افزونه قدرتمند MPV (نیاز به دانلود و معرفی مسیر)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,0,10" GroupName="PlayerSelection"/>
                                <TextBox Text="{Binding MpvPath, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:HintAssist.Hint="مسیر فایل اجرایی mpv.exe (اختیاری اگر در پوشه برنامه است)" 
                                         Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="35,0,0,20"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         IsEnabled="{Binding IsPluginPlayer}"/>
                                <TextBlock Text="راهنما: ابتدا نرم‌افزار MPV را دانلود کرده و سپس مسیر فایل اجرایی آن را در اینجا قرار دهید." 
                                           Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="35,0,0,30" 
                                           Visibility="{Binding IsPluginPlayer, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <Separator Background="{DynamicResource NormalBorder}" Margin="0,10,0,25"/>

                                <TextBlock Text="زبان دریافت اطلاعات (برای سایت‌هایی که پشتیبانی می‌کنند مانند TMDb)" Foreground="{DynamicResource SecondaryText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,35">
                                    <RadioButton IsChecked="{Binding IsPersianLanguage}" Content="فارسی" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,30,0" GroupName="Languages"/>
                                    <RadioButton IsChecked="{Binding IsEnglishLanguage}" Content="انگلیسی" Foreground="{DynamicResource PrimaryText}" FontSize="16" GroupName="Languages"/>
                                </StackPanel>

                                <Button Command="{Binding SaveSettingsCommand}" 
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{DynamicResource SuccessColor}" Foreground="#050510" BorderThickness="0" 
                                        HorizontalAlignment="Left" Padding="20,0" Height="45" materialDesign:ButtonAssist.CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="ذخیره تنظیمات عمومی" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. Appearance -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" MinWidth="180">
                        <materialDesign:PackIcon Kind="PaletteOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="شخصی‌سازی ظاهر" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,20,0">
                    <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                        <materialDesign:Card Background="{DynamicResource CardBackground}" UniformCornerRadius="16" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <materialDesign:PackIcon Kind="Palette" Foreground="{DynamicResource PrimaryColor}" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="ظاهر برنامه" Foreground="{DynamicResource PrimaryText}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="حالت نمایش (تم):" Foreground="{DynamicResource SecondaryText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                                    <RadioButton IsChecked="{Binding IsDarkTheme}" Content="تاریک (Dark)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,30,0" GroupName="Mode"/>
                                    <RadioButton IsChecked="{Binding IsLightTheme}" Content="روشن (Light)" Foreground="{DynamicResource PrimaryText}" FontSize="16" GroupName="Mode"/>
                                </StackPanel>
                                
                                <Separator Background="{DynamicResource NormalBorder}" Margin="0,0,0,25"/>

                                <TextBlock Text="رنگ‌بندی کلی برنامه را تغییر دهید:" Foreground="{DynamicResource SecondaryText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton IsChecked="{Binding IsCyan}" Content="فیروزه‌ای (Cyan)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,30,0" GroupName="Themes"/>
                                    <RadioButton IsChecked="{Binding IsMidnightBlue}" Content="آبی نیمه‌شب (Midnight Blue)" Foreground="{DynamicResource PrimaryText}" FontSize="16" Margin="0,0,30,0" GroupName="Themes"/>
                                    <RadioButton IsChecked="{Binding IsOLEDBlack}" Content="مشکی مطلق (OLED Black)" Foreground="{DynamicResource PrimaryText}" FontSize="16" GroupName="Themes"/>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 3. Data Management -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" MinWidth="180">
                        <materialDesign:PackIcon Kind="DatabaseOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="مدیریت اطلاعات" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,20,0">
                    <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                        <!-- Cloud Backup Card (Google Drive) -->
                        <materialDesign:Card Background="{DynamicResource CardBackground}" UniformCornerRadius="16" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <materialDesign:PackIcon Kind="CloudSync" Foreground="{DynamicResource PrimaryColor}" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="پشتیبان‌گیری ابری (Google Drive)" Foreground="{DynamicResource PrimaryText}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- Connection Status -->
                                <Border Background="#1A3A86FF" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                    <Grid>
                                        <!-- Not Connected -->
                                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsNotGoogleDriveConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="GoogleDrive" Foreground="#3A86FF" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="به حساب گوگل متصل نیستید." Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                            <Button Command="{Binding ConnectToGoogleDriveCommand}" Content="اتصال به حساب گوگل" Style="{StaticResource MaterialDesignRaisedButton}" Background="#3A86FF" Foreground="White" BorderThickness="0" Height="35" materialDesign:ButtonAssist.CornerRadius="6"/>
                                        </StackPanel>
                                        
                                        <!-- Connected -->
                                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsGoogleDriveConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="{DynamicResource SuccessColor}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="شما به حساب گوگل متصل هستید." Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                            <Button Command="{Binding DisconnectGoogleDriveCommand}" Content="قطع اتصال" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{DynamicResource ErrorColor}" BorderBrush="{DynamicResource ErrorColor}" Height="35" materialDesign:ButtonAssist.CornerRadius="6"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Cloud Auto Backup Settings -->
                                <StackPanel IsEnabled="{Binding IsGoogleDriveConnected}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <ToggleButton IsChecked="{Binding IsGoogleDriveAutoBackupEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <TextBlock Text="آپلود خودکار در گوگل درایو" Foreground="{DynamicResource PrimaryText}" FontSize="16" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        <Button Command="{Binding TestGoogleDriveCommand}" IsEnabled="{Binding IsUploadingBackup, Converter={StaticResource InverseBooleanConverter}}" Content="ساخت بکاپ جدید" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#3A86FF" BorderBrush="#3A86FF" Height="35" materialDesign:ButtonAssist.CornerRadius="6" Visibility="{Binding IsGoogleDriveAutoBackupEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <!-- Upload Progress -->
                                    <StackPanel Visibility="{Binding IsUploadingBackup, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,20">
                                        <TextBlock Text="{Binding BackupProgressText}" Foreground="{DynamicResource SecondaryText}" FontSize="14" Margin="0,0,0,5"/>
                                        <ProgressBar Value="{Binding BackupProgressValue}" Minimum="0" Maximum="100" Height="8" Foreground="#3A86FF" Background="{DynamicResource NormalBorder}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                        <TextBlock Text="زمان‌بندی بک‌آپ:" Foreground="{DynamicResource SecondaryText}" FontSize="15" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <ComboBox SelectedIndex="{Binding BackupFrequencyIndex}" Width="200" Foreground="{DynamicResource PrimaryText}">
                                            <ComboBoxItem Content="همیشه هنگام خروج" />
                                            <ComboBoxItem Content="یک‌بار در روز" />
                                            <ComboBoxItem Content="یک‌بار در هفته" />
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>

                                <Separator Background="{DynamicResource NormalBorder}" Margin="0,10,0,20"/>

                                <!-- Cloud Backups List -->
                                <StackPanel IsEnabled="{Binding IsGoogleDriveConnected}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <TextBlock Text="بکاپ‌های ذخیره شده در درایو شما" Foreground="{DynamicResource PrimaryText}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button Command="{Binding LoadCloudBackupsCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30" Margin="10,0,0,0" ToolTip="بروزرسانی لیست">
                                            <materialDesign:PackIcon Kind="Refresh" Foreground="{DynamicResource SecondaryText}"/>
                                        </Button>
                                    </StackPanel>
                                    
                                    <ProgressBar IsIndeterminate="True" Visibility="{Binding IsLoadingBackups, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,10"/>
                                    
                                    <DataGrid ItemsSource="{Binding CloudBackups}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" Foreground="{DynamicResource PrimaryText}" RowBackground="Transparent" AlternatingRowBackground="{DynamicResource HoverBackground}" BorderThickness="1" BorderBrush="{DynamicResource NormalBorder}" materialDesign:DataGridAssist.CornerRadius="8" MaxHeight="250" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="نام فایل" Binding="{Binding Name}" Width="2*"/>
                                            <DataGridTextColumn Header="تاریخ و ساعت" Binding="{Binding CreatedTime, StringFormat='{}{0:yyyy/MM/dd HH:mm}'}" Width="1.5*"/>
                                            <DataGridTextColumn Header="حجم" Binding="{Binding FormattedSize}" Width="1*"/>
                                            <DataGridTemplateColumn Header="عملیات" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Command="{Binding DataContext.DownloadAndRestoreCloudBackupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" ToolTip="دانلود و بازیابی (اعمال روی دیتابیس)">
                                                                <materialDesign:PackIcon Kind="DownloadNetwork" Foreground="{DynamicResource PrimaryColor}"/>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.ShareCloudBackupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" ToolTip="دریافت لینک اشتراک‌گذاری">
                                                                <materialDesign:PackIcon Kind="ShareVariant" Foreground="{DynamicResource WarningColor}"/>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.DeleteCloudBackupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" ToolTip="حذف از گوگل درایو">
                                                                <materialDesign:PackIcon Kind="Delete" Foreground="{DynamicResource ErrorColor}"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>

                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Local Backup Card -->
                        <materialDesign:Card Background="{DynamicResource CardBackground}" UniformCornerRadius="16" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <materialDesign:PackIcon Kind="Harddisk" Foreground="{DynamicResource PrimaryColor}" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="پشتیبان‌گیری محلی (سیستم)" Foreground="{DynamicResource PrimaryText}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                    <Button Command="{Binding ExportJsonCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{DynamicResource PrimaryColor}" BorderBrush="{DynamicResource PrimaryColor}" HorizontalAlignment="Left" Width="210" Height="45" Margin="0,0,20,0" materialDesign:ButtonAssist.CornerRadius="8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Export" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,10,0"/>
                                            <TextBlock Text="تهیه خروجی (Export)" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding ImportJsonCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{DynamicResource WarningColor}" BorderBrush="{DynamicResource WarningColor}" HorizontalAlignment="Left" Width="210" Height="45" materialDesign:ButtonAssist.CornerRadius="8">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Import" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,10,0"/>
                                            <TextBlock Text="بازیابی از فایل (Import)" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <ToggleButton IsChecked="{Binding IsLocalAutoBackupEnabled}" Style="{StaticResource MaterialDesignSwitchToggleButton}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    <TextBlock Text="ذخیره خودکار روی سیستم هنگام خروج (حداکثر ۵ نسخه)" Foreground="{DynamicResource PrimaryText}" FontSize="16" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="30,0,0,0" Visibility="{Binding IsLocalAutoBackupEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBox Text="{Binding LocalAutoBackupPath}" Width="350" materialDesign:HintAssist.Hint="پوشه ذخیره پشتیبان..." IsReadOnly="True" Foreground="{DynamicResource PrimaryText}" Margin="0,0,15,0"/>
                                    <Button Command="{Binding BrowseBackupPathCommand}" Content="انتخاب پوشه" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </StackPanel>

                            </StackPanel>
                        </materialDesign:Card>

                        <Button Command="{Binding SaveSettingsCommand}" 
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource SuccessColor}" Foreground="#050510" BorderThickness="0" 
                                HorizontalAlignment="Left" Padding="20,0" Height="45" Margin="0,10,20,20" materialDesign:ButtonAssist.CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="ذخیره تنظیمات پشتیبان" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Danger Zone Card -->
                        <materialDesign:Card Background="#0DFF5252" UniformCornerRadius="16" Padding="30">
                            <materialDesign:Card.Style>
                                <Style TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush" Value="#4DFF5252"/>
                                </Style>
                            </materialDesign:Card.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="{DynamicResource ErrorColor}" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="منطقه خطرناک" Foreground="{DynamicResource ErrorColor}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="عملیات زیر غیرقابل بازگشت است و تمام اطلاعات دیتابیس فیلم‌ها و سریال‌های برنامه را به‌طور کامل پاک می‌کند. فایل‌های روی سیستم شما حذف نخواهند شد." Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,30" TextWrapping="Wrap" FontSize="15" LineHeight="26"/>
                                
                                <Button Command="{Binding ClearDatabaseCommand}" 
                                        Background="{DynamicResource ErrorColor}" BorderBrush="{DynamicResource ErrorColor}" Foreground="White" 
                                        HorizontalAlignment="Left" Width="250" Height="50" materialDesign:ButtonAssist.CornerRadius="8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DatabaseRemove" VerticalAlignment="Center" Width="22" Height="22" Margin="0,0,10,0"/>
                                        <TextBlock Text="حذف کامل دیتابیس" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
