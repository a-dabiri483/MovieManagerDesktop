<UserControl x:Class="MovieManagerDesktop.Controls.AlertDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             FlowDirection="RightToLeft"
             Width="400" MaxWidth="500">
             
    <UserControl.Resources>
        <system:Boolean x:Key="TrueValue">True</system:Boolean>
    </UserControl.Resources>

    <Border Background="#2A2A35" CornerRadius="12" Padding="25">
        <StackPanel>
            <materialDesign:PackIcon Kind="InformationOutline" Width="48" Height="48" 
                                     Foreground="{DynamicResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock Text="{Binding Message}" Foreground="White" FontSize="16" 
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25" LineHeight="24"/>
            
            <Button Content="تایید" 
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                    CommandParameter="{StaticResource TrueValue}"
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Background="#20FFFFFF" Foreground="White" Height="40" materialDesign:ButtonAssist.CornerRadius="8" Width="120" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
