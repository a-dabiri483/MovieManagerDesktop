<UserControl x:Class="MovieManagerDesktop.Controls.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             FlowDirection="RightToLeft"
             Width="400" MaxWidth="500">
             
    <UserControl.Resources>
        <system:Boolean x:Key="TrueValue">True</system:Boolean>
        <system:Boolean x:Key="FalseValue">False</system:Boolean>
    </UserControl.Resources>

    <Border Background="#2A2A35" CornerRadius="12" Padding="25">
        <StackPanel>
            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="48" Height="48" 
                                     Foreground="#FF5252" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock Text="{Binding Message}" Foreground="White" FontSize="16" 
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,25" LineHeight="24"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="بله، اطمینان دارم" 
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                        CommandParameter="{StaticResource TrueValue}"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Background="#20FF5252" Foreground="#FF5252" Height="40" materialDesign:ButtonAssist.CornerRadius="8"/>
                        
                <Button Grid.Column="2" Content="انصراف" 
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                        CommandParameter="{StaticResource FalseValue}"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Background="#20FFFFFF" Foreground="White" Height="40" materialDesign:ButtonAssist.CornerRadius="8"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
